# Application
APP_NAME=Elder Care Assistant
ENV=development
DEBUG=True
SECRET_KEY=change-this-secret-key

# Backend API used by streamlit_app.py
API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg://elder_user:elder_password@localhost:5432/elder_care_db
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=0.5
JWT_REFRESH_EXPIRATION_DAYS=7

# Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Logging
LOG_LEVEL=INFO

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=noreply@eldercareassistant.com

# SMS / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

